  "tokenColors": [

    {
      "name": "─── RESET / PLAIN TEXT ───────────────────────",
      "scope": [""],
      "settings": { "foreground": "#abb2bf" }
    },

    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5c6370",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Doc comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#5c6370",
        "fontStyle": "italic"
      }
    },

    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "storage.type",
        "storage.modifier"
      ],
      "settings": { "foreground": "#c678dd" }
    },
    {
      "name": "Keywords — control flow (import / export / async / await)",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.async",
        "keyword.control.await",
        "keyword.control.flow",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.of",
        "meta.import keyword",
        "source.python keyword.control.import",
        "source.python keyword.control.from"
      ],
      "settings": { "foreground": "#c678dd" }
    },

    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "string.interpolated",
        "meta.embedded.line.string"
      ],
      "settings": { "foreground": "#98c379" }
    },
    {
      "name": "String escape sequences",
      "scope": [
        "constant.character.escape",
        "string.regexp.character-class"
      ],
      "settings": { "foreground": "#56b6c2" }
    },
    {
      "name": "Template literal expression punctuation",
      "scope": [
        "punctuation.definition.template-expression"
      ],
      "settings": { "foreground": "#c678dd" }
    },

    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.hex",
        "constant.numeric.octal",
        "constant.numeric.binary",
        "constant.numeric.float"
      ],
      "settings": { "foreground": "#d19a66" }
    },

    {
      "name": "Constants (true / false / null / undefined / None)",
      "scope": [
        "constant.language",
